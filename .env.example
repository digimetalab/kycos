# ============================================
# KYCOS — Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================

# --- AI Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
GOOGLE_AI_API_KEY=AIzaSyxxxxx
OPENROUTER_API_KEY=sk-or-xxxxx

# --- Local AI (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- OSINT API Keys ---
SHODAN_API_KEY=
HIBP_API_KEY=
OPENCORPORATES_API_KEY=

# --- Security ---
KYCOS_ENCRYPTION_KEY=change-this-to-a-32-char-secret!
KYCOS_DATA_DIR=./data

# --- Operational ---
KYCOS_LOG_LEVEL=info
KYCOS_CACHE_TTL_HOURS=24
KYCOS_MAX_CONCURRENT_AGENTS=7
KYCOS_RATE_LIMIT_MS=1000
